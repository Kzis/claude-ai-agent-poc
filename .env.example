# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Notion Integration
# Create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Parent page ID where agent will create all databases
# Copy from the URL of a Notion page: notion.so/<workspace>/<PAGE_ID>
NOTION_PARENT_PAGE_ID=your-notion-parent-page-id-here

# Notion Database IDs (auto-filled after running `npm run setup-notion`)
NOTION_BACKLOG_DB_ID=
NOTION_BUG_REPORTS_DB_ID=
NOTION_RELEASES_DB_ID=
NOTION_METRICS_DB_ID=

# GitHub
# Create a personal access token at https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
# Base branch for all PRs (usually main or master)
GITHUB_BASE_BRANCH=main
